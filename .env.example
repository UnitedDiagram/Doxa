# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DOXA_LOG_LEVEL=INFO

# Price history period passed to yfinance (e.g. 1y, 6mo, 3mo)
DOXA_HISTORY_PERIOD=1y

# Anthropic API key for Claude-powered sentiment analysis
ANTHROPIC_API_KEY=your_key_here

# Maximum number of headlines to send to Claude for sentiment analysis
DOXA_MAX_HEADLINES=10

# Cache backend type (currently only "memory" supported)
DOXA_CACHE_BACKEND=memory

# Maximum number of entries in the in-memory cache (0 = unlimited)
DOXA_CACHE_MAX_ENTRIES=1000
